<Window x:Class="WpfApp2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Rectangle HorizontalAlignment="Left" Height="340" Margin="68,11,0,0" Stroke="#FFA79900" VerticalAlignment="Top" Width="340" Fill="#FFFFF500"/>
        <Rectangle HorizontalAlignment="Left" Height="320" Margin="78,21,0,0" Stroke="Black" VerticalAlignment="Top" Width="320" Fill="#FF879600"/>
        <Grid Height="320" Width="320" x:Name="PuzzleGrid" Margin="78,21,0,0" HorizontalAlignment="Left" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="80"/>
                <RowDefinition Height="80"/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>

        </Grid>
        <Button Content="Shuffle" Margin="68,356,0,0" x:Name="ShuffleButton" Click="ShuffleButton_Click" HorizontalAlignment="Left" VerticalAlignment="Top" Width="340" FontFamily="Bahnschrift SemiLight Condensed" Height="31"/>
    </Grid>
</Window>
